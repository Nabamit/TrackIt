# Django settings
USE_SQLITE=True
SECRET_KEY=django-insecure-your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL / Supabase database settings
USE_SQLITE=True # Set to False to connect to Supabase
DB_NAME=postgres # Usually 'postgres' on Supabase
DB_USER=postgres # Usually 'postgres' on Supabase
DB_PASSWORD=your-supabase-db-password
DB_HOST=db.your-supabase-project-ref.supabase.co
DB_PORT=5432 # Use 5432 for direct connection, or 6543 for pooling
DB_SSLMODE=require # Supabase requires SSL connections

